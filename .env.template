# Example .env file for Kurs Bot
# Copy this file to .env and fill in your real secrets

# Production database (clean, no test data)
DATABASE_URL=sqlite:///./kurs-bot/src/data/prod.db

# For development/testing with test data, use:
# DATABASE_URL=sqlite:///d:/dev/kurs-bot/src/data/dev.db

# Messaging integrations
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SLACK_BOT_TOKEN=
SENDGRID_API_KEY=

# Ollama settings (local LLM)
OLLAMA_URL=http://localhost:11434/api/generate # Local
OLLAMA_MODEL=llama3.1:8b

# Optional API key for Ollama Cloud / authenticated Ollama endpoints
OLLAMA_API_KEY=
#OLLAMA_URL=https://ollama.com/

# Ollama embedding settings (for semantic search)
OLLAMA_EMBED_URL=http://localhost:11434/api/embed
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
EMBEDDING_DIMENSION=768
SEMANTIC_SEARCH_THRESHOLD=0.4
SEMANTIC_SEARCH_MAX_RESULTS=5

TEST_USE_REAL_OLLAMA=False
TEST_OLLAMA_MODEL="llama3.2:3b"
TEST_OLLAMA_CHAT_RAG_MODEL="llama3.2:3b"
TEST_NON_ENGLISH_OLLAMA_MODEL="llama3.2:3b"

# GDPR / retention settings
GDPR_ADMIN_TOKEN=your-gdpr-admin-token
API_AUTH_TOKEN=your-api-auth-token
MESSAGE_LOG_RETENTION_DAYS=30
MEMORY_ARCHIVE_RETENTION_DAYS=365
GDPR_VERIFICATION_TTL_MINUTES=10
GDPR_VERIFICATION_MAX_ATTEMPTS=3
GDPR_VERIFICATION_CODE_LENGTH=6

# System prompt for dialogue engine
SYSTEM_PROMPT=You are a spiritual coach specializing in A Course in Miracles. Respond with wisdom, compassion, and practical spiritual guidance. Always respond in the same language as the user.