# Example .env file for Kurs Bot
# Copy this file to .env and fill in your real secrets

# Production database (clean, no test data)
DATABASE_URL="sqlite:///./src/data/prod.db"

# For development/testing with test data, use:
#DATABASE_URL="sqlite:///./src/data/dev.db"

# Messaging integrations
TELEGRAM_BOT_TOKEN=bot:TESTTOKEN
ADMIN_TELEGRAM_USERNAME=johannes_steen
SLACK_BOT_TOKEN=
SENDGRID_API_KEY=

# Ollama settings (local and cloud)
LOCAL_OLLAMA_URL=http://localhost:11434/api/generate
CLOUD_OLLAMA_URL=https://ollama.com/api/generate
# Optional API key for Ollama Cloud / authenticated Ollama endpoints
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:20b-cloud
NON_ENGLISH_OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_CHAT_RAG_MODEL=qwen3-coder-next:cloud
# Ollama embedding settings (for semantic search) (not used if EMBEDDING_BACKEND=local)
OLLAMA_EMBED_URL=http://localhost:11434/api/embed
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Embedding backend switch: 'ollama' or 'local'.
# IMPORTANT: `TEST_USE_REAL_OLLAMA` controls whether tests mock the LLM
# service — it does NOT automatically switch the embedding backend.
# Set `EMBEDDING_BACKEND` explicitly to avoid silent dimension mismatches.
# Examples:
# - For local sentence-transformers (all-MiniLM-L6-v2) use:
#     EMBEDDING_BACKEND=local
#     SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2
#     EMBEDDING_DIMENSION=384
# - For Ollama embeddings use:
#     EMBEDDING_BACKEND=ollama
#     OLLAMA_EMBED_MODEL=nomic-embed-text:latest
#     EMBEDDING_DIMENSION=768
EMBEDDING_BACKEND=local
SENTENCE_TRANSFORMERS_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
#$env:PYTHONPATH='.'; python .\scripts\reset_trigger_embeddings.py
HNSWLIB_INDEX_PATH=src/data/emb_index.bin
SEMANTIC_SEARCH_THRESHOLD=0.4
SEMANTIC_SEARCH_MAX_RESULTS=5

# Ollama settings
# In production you normally want real Ollama calls: leave USE_REAL_OLLAMA=True.
# For local testing without Ollama, set USE_REAL_OLLAMA=False and tests will use mock responses.
USE_REAL_OLLAMA=True
# TEST_USE_REAL_OLLAMA is a safety flag for CI; leave commented in prod.
# TEST_USE_REAL_OLLAMA=False
TEST_OLLAMA_MODEL="llama3.2:3b"
TEST_OLLAMA_CHAT_RAG_MODEL="llama3.2:3b"
TEST_NON_ENGLISH_OLLAMA_MODEL="llama3.2:3b"

# GDPR / retention settings
GDPR_ADMIN_TOKEN=your-gdpr-admin-token
API_AUTH_TOKEN=your-api-auth-token
MESSAGE_LOG_RETENTION_DAYS=30
MEMORY_ARCHIVE_RETENTION_DAYS=365
GDPR_VERIFICATION_TTL_MINUTES=10
GDPR_VERIFICATION_MAX_ATTEMPTS=3
GDPR_VERIFICATION_CODE_LENGTH=6

# System prompt for dialogue engine
SYSTEM_PROMPT=You are a spiritual coach specializing in A Course in Miracles. Respond with wisdom, compassion, and practical spiritual guidance. Make always short replies with unconditional universal love. You also know: Impersonal Life, by Joseph Benner as a background, but do not have to talk about it. But reflect these principles too in your conversation. Be kind, warm and gentle. The user sees the text on a small screen, so keep the text easy to read.
